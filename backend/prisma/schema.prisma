generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENTE
}

enum ContractType {
  FIXO
  FLEX
  SERVICO
  CUSTOM
  AVULSO
}

enum Tier {
  COMERCIAL
  AUDIENCIA
  SABADO
}

enum BookingStatus {
  RESERVED
  CONFIRMED
  HELD
  COMPLETED
  FALTA
  NAO_REALIZADO
  CANCELLED
}

enum ContractStatus {
  ACTIVE
  AWAITING_PAYMENT
  EXPIRED
  CANCELLED
  PENDING_CANCELLATION
  PAUSED
}

enum PaymentProvider {
  STRIPE
  CORA
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED // installment voided because its contract was cancelled (not a failed charge)
}

enum PaymentMethod {
  CARTAO
  PIX
  BOLETO
}

enum NotificationType {
  CONTRACT_EXPIRING
  PAYMENT_OVERDUE
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  BOOKING_UNCONFIRMED
  BOOKING_REMINDER
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  CONTRACT_ACTIVATED
  CONTRACT_RENEWED
  CANCELLATION_PENDING
  FLEX_CREDITS_LOW
  CLIENT_INACTIVE
  CONTRACT_AWAITING_PAYMENT
  SYSTEM
  // NOTE: CONTRACT_RENEWED, CLIENT_INACTIVE and SYSTEM are no longer produced (pruned in
  // jun/2026) but kept in the enum to match the existing Postgres type — dropping enum values
  // requires a risky --accept-data-loss migration and adds no runtime benefit since nothing
  // emits them. Safe to remove later via a dedicated migration if desired.
}

// ─── Models ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  name         String
  phone        String?
  googleId     String?  @unique @map("google_id")
  role         Role     @default(CLIENTE)
  photoUrl     String?  @map("photo_url")
  notes        String?  @db.Text // admin internal observations
  cpfCnpj      String?  @unique @map("cpf_cnpj")
  address      String?  @db.Text
  city         String?
  state        String?
  tags         String[] @default([])
  socialLinks  String?  @map("social_links") @db.Text // JSON: {"youtube":"url","instagram":"url",...}
  clientStatus String   @default("ACTIVE") @map("client_status") // ACTIVE, INACTIVE, BLOCKED
  stripeCustomerId  String?  @unique @map("stripe_customer_id")
  autoChargeEnabled Boolean  @default(false) @map("auto_charge_enabled")
  // When true, only critical notifications (payments, credit loss) are delivered.
  essentialNotificationsOnly Boolean @default(false) @map("essential_notifications_only")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bookings            Booking[]
  contracts           Contract[]
  payments            Payment[]
  blockedSlots        BlockedSlot[]
  savedPaymentMethods SavedPaymentMethod[]
  pushSubscriptions   PushSubscription[]
  notifications       Notification[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Contract {
  id             String         @id @default(uuid())
  name           String // e.g "Podcast Verão", "Avulso"
  userId         String         @map("user_id")
  type           ContractType
  tier           Tier
  durationMonths Int            @map("duration_months") // 3 or 6
  discountPct    Int            @map("discount_pct") // 30 or 40
  startDate      DateTime       @map("start_date")
  endDate        DateTime       @map("end_date")
  status         ContractStatus @default(ACTIVE)

  // Fixo-specific
  fixedDayOfWeek Int?    @map("fixed_day_of_week") // 1=Mon, 6=Sat
  fixedTime      String? @map("fixed_time") // "14:00"

  // Store credits refunded due to early cancellations (only used for CUSTOM)
  customCreditsRemaining Int @default(0) @map("custom_credits_remaining")

  // For FIXO contracts link
  contractUrl String? @map("contract_url") // link to digital contract

  // Flex-specific (episode-based credits: 12 for 3mo, 24 for 6mo)
  flexCreditsTotal     Int?      @map("flex_credits_total") // 12 or 24 episodes
  flexCreditsRemaining Int?      @map("flex_credits_remaining")
  flexCycleStart       DateTime? @map("flex_cycle_start")
  flexWeeksCompensated Int?      @default(0) @map("flex_weeks_compensated") // advance offset
  // Weekly-window engine: credits forfeited for falling behind the weekly pace (monotonic).
  flexCreditsForfeited Int       @default(0) @map("flex_credits_forfeited")
  // Grandfather baseline: shortfall already incurred when forfeiture went live for this
  // contract (NULL = not yet initialized → cron sets it on first sight, no retroactive loss).
  flexForfeitFloor     Int?      @map("flex_forfeit_floor")

  // Custom-specific ("Monte Seu Plano")
  customSchedule    String?  @map("custom_schedule") @db.Text // JSON: [{"day":1,"time":"10:00"},{"day":3,"time":"19:30"}]
  sessionsPerWeek   Int?     @map("sessions_per_week")
  sessionsPerCycle   Int?     @map("sessions_per_cycle")  // sessionsPerWeek × 4
  totalSessions     Int?     @map("total_sessions")
  addonCredits      String?  @map("addon_credits") @db.Text // JSON: {"CORTES_REELS":{"mode":"all"},"GUEST_VIP":{"mode":"credits","perCycle":4}}
  accessMode        String?  @map("access_mode") // FULL (cartão/pix) or PROGRESSIVE (boleto)

  // Add-ons selected at contract creation
  addOns               String[]  @map("add_ons")

  // Payment method chosen at contract creation
  paymentMethod PaymentMethod? @map("payment_method")

  // Admin can release boleto for this specific contract (off by default)
  boletoAllowed Boolean @default(false) @map("boleto_allowed")

  // How the contract is paid: MONTHLY (1 now + rest monthly) or FULL (paid upfront)
  paymentPlan String @default("MONTHLY") @map("payment_plan")

  // Pause / Renewal
  pausedAt        DateTime? @map("paused_at")
  pauseReason     String?   @map("pause_reason")
  resumeDate      DateTime? @map("resume_date")
  paymentDeadline DateTime? @map("payment_deadline")
  renewedFromId   String?   @map("renewed_from_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id])
  bookings    Booking[]
  payments    Payment[]
  renewedFrom Contract? @relation("ContractRenewal", fields: [renewedFromId], references: [id])
  renewals    Contract[] @relation("ContractRenewal")

  @@index([userId])
  @@index([endDate])
  @@map("contracts")
}

model Booking {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  contractId    String        @map("contract_id")
  date          DateTime      @db.Date
  startTime     String        @map("start_time") // "14:00"
  endTime       String        @map("end_time") // "16:00"
  status        BookingStatus @default(RESERVED)
  tierApplied   Tier          @map("tier_applied")
  price         Int // in cents (R$ 300,00 = 30000)
  adminNotes    String?       @map("admin_notes") @db.Text // admin-only observations
  clientNotes   String?       @map("client_notes") @db.Text // visible to client
  originalDate  DateTime?     @map("original_date") @db.Date // anchor date for 7-day reschedule window
  platforms     String?       @map("platforms") // JSON array: ["YOUTUBE","TIKTOK",...]
  platformLinks String?       @map("platform_links") @db.Text // JSON object: {"YOUTUBE":"url",...}
  addOns        String[]      @map("add_ons")
  holdExpiresAt DateTime?     @map("hold_expires_at")

  // Phase 2 Analytical Metrics
  durationMinutes Int?    @map("duration_minutes")
  peakViewers     Int?    @map("peak_viewers")
  chatMessages    Int?    @map("chat_messages")
  audienceOrigin  String? @map("audience_origin")
  // Livestream finalization: whether the recording was broadcast live, and per-network
  // metrics captured at finalization. streamMetrics is JSON keyed by platform:
  // {"YOUTUBE":{"views":N,"peak":N,"likes":N,"comments":N}, ...}. peakViewers/chatMessages
  // above are kept as derived aggregates (max peak / sum comments) for legacy displays.
  isLivestream  Boolean? @map("is_livestream")
  streamMetrics String?  @map("stream_metrics") @db.Text

  // Episode metadata (client-editable) + optimized cover image shown in recordings.
  episodeTitle       String? @map("episode_title")
  episodeDescription String? @map("episode_description") @db.Text
  coverImageUrl      String? @map("cover_image_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  contract Contract  @relation(fields: [contractId], references: [id])
  payments Payment[]

  // Prevent double booking: Redis lock is primary protection, this index aids queries
  @@index([date, startTime, status], name: "idx_booking_date_time_status")
  @@index([userId])
  @@index([contractId])
  @@index([date])
  @@index([status])
  @@map("bookings")
}

model Payment {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  contractId  String?         @map("contract_id")
  bookingId   String?         @map("booking_id")
  provider    PaymentProvider
  providerRef String?         @map("provider_ref")
  amount      Int // in cents
  status      PaymentStatus   @default(PENDING)
  dueDate     DateTime?       @map("due_date")
  pixString   String?         @map("pix_string") @db.Text
  boletoUrl   String?         @map("boleto_url") @db.Text
  paymentUrl  String?         @map("payment_url") @db.Text // Checkout Link
  installments         Int?      @default(1)  // number of installments
  paymentType          String?   @map("payment_type")  // DEBIT | CREDIT
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  metadata    Json?               // Pending contract data, addon keys, etc.
  paidAt      DateTime?       @map("paid_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([contractId])
  @@index([bookingId])
  @@index([providerRef])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@index([dueDate])
  @@map("payments")
}

model SavedPaymentMethod {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  stripePaymentMethodId String   @unique @map("stripe_pm_id")
  brand                 String   // visa, mastercard, elo, etc.
  last4                 String
  expMonth              Int      @map("exp_month")
  expYear               Int      @map("exp_year")
  isDefault             Boolean  @default(false) @map("is_default")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_payment_methods")
}

model BlockedSlot {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@map("blocked_slots")
}

model PricingConfig {
  id          String   @id @default(uuid())
  tier        Tier     @unique
  price       Int // in cents (R$ 300,00 = 30000)
  label       String // "Comercial", "Audiência", "Sábado"
  description String?  @db.Text // plan description
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pricing_config")
}

model AddOnConfig {
  key         String   @id // e.g. "CORTES_IA", "YOUTUBE_SEO", "PAUTAS"
  name        String
  price       Int      // Base price in cents
  description String?  @db.Text
  monthly     Boolean  @default(false) // family discriminator: true = monthly service (e.g. GESTAO_SOCIAL), false = per-episode add-on
  // ── Admin-editable display + service-contract metadata ──
  active           Boolean @default(true) // soft-delete / on-off toggle
  sortOrder        Int     @default(0) @map("sort_order") // ordering on landing + admin
  icon             String? @default("Sparkles") // lucide icon name OR emoji
  showOnLanding    Boolean @default(true) @map("show_on_landing") // appears in the public ServicesCarousel
  benefits         String? @db.Text // JSON string[] of bullet points (monthly services)
  durationsOffered String  @default("3,6") @map("durations_offered") // CSV of fidelity options (months)
  plansAllowed     String  @default("FULL") @map("plans_allowed") // CSV: FULL and/or MONTHLY
  billingCadence   String  @default("BILLING_CYCLE_28") @map("billing_cadence") // BILLING_CYCLE_28 | CALENDAR_MONTH
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("addon_config")
}

model BusinessConfig {
  key       String   @id  // e.g. "discount_3months", "sessions_per_month"
  value     String        // serialized value (number, percent, string)
  type      String        // "number" | "percent" | "string"
  label     String        // human-readable label shown in Admin UI
  group     String        // "plans" | "policies" | "payments"
  updatedAt DateTime @updatedAt @map("updated_at")


  @@map("business_config")
}

model PaymentMethodConfig {
  key         String   @id              // "PIX", "CARTAO", "BOLETO"
  label       String                    // "PIX", "Cartão de Crédito"
  shortLabel  String   @map("short_label")  // "PIX", "Cartão"
  emoji       String                    // "⚡", "💳", "📄"
  description String                    // "Pagamento instantâneo"
  color       String                    // "#22c55e"
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)      @map("sort_order")
  accessMode  String   @default("FULL") @map("access_mode") // "FULL" | "PROGRESSIVE"
  // CSV of checkout contexts where this method appears: avulso, contract, invoice
  contexts    String   @default("avulso,contract,invoice")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  @@map("payment_method_config")
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String   @map("entity_type") // CONTRACT, USER, BOOKING
  entityId    String   @map("entity_id")
  action      String   // CREATED, UPDATED, CANCELLED, PAUSED, RESUMED, RENEWED
  changes     String?  @db.Text // JSON diff
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationConfig {
  id           String    @id @default(uuid())
  provider     String    @unique           // "CORA" | "STRIPE"
  enabled      Boolean   @default(false)
  environment  String    @default("sandbox") // "sandbox" | "production"
  config       String    @db.Text          // JSON with credentials
  webhookUrl   String?   @map("webhook_url") @db.Text
  lastTestedAt DateTime? @map("last_tested_at")
  testStatus   String?   @map("test_status") // "success" | "error" | null
  testMessage  String?   @map("test_message") @db.Text
  updatedAt    DateTime  @updatedAt        @map("updated_at")

  @@map("integration_configs")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  severity    String           @default("info") // critical, warning, info
  title       String
  message     String           @db.Text
  entityType  String?          @map("entity_type")
  entityId    String?          @map("entity_id")
  actionUrl   String?          @map("action_url")
  read        Boolean          @default(false)
  pushSent    Boolean          @default(false) @map("push_sent")
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

