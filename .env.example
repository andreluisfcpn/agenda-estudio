# Database
DATABASE_URL=postgresql://studio:studio_secret@localhost:5432/studio_scheduler

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Encryption (separate from JWT — generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Payment Providers (stubs for now)
STRIPE_SECRET_KEY=sk_test_placeholder
CORA_API_KEY=cora_test_placeholder
CORA_API_URL=https://api.cora.com.br

# Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=change-me-generate-vapid-keys
VAPID_PRIVATE_KEY=change-me-generate-vapid-keys
VAPID_SUBJECT=mailto:your@email.com

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Dev-only: accept unsigned webhooks for local testing (NEVER set in production)
# ALLOW_UNVERIFIED_WEBHOOKS=true

# Dev-only: accept OTP code 999999 for testing (NEVER set in production)
# ALLOW_OTP_BYPASS=true
